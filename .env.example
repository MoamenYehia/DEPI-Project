# =============================================================
# AI Business Intelligence Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================

# ---------------------------------------------------------
# LLM Provider  (pick ONE)
# Options:  groq | ollama | azure
# ---------------------------------------------------------
#   groq   → Groq cloud API, fast & free tier, needs GROQ_API_KEY
#   ollama → fully local (private), no API key, needs Ollama running
#   azure  → Azure OpenAI, production path, needs AZURE_* keys
LLM_PROVIDER=groq

# ---------------------------------------------------------
# Groq  (https://console.groq.com — free account)
# ---------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here
# Available models: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
GROQ_MODEL=llama3-8b-8192

# ---------------------------------------------------------
# Ollama  (https://ollama.ai — fully local)
# Start with:  ollama pull llama3 && ollama serve
# ---------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---------------------------------------------------------
# Azure OpenAI  (production)
# ---------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# ---------------------------------------------------------
# MLflow  (default: local SQLite — no server setup needed)
# ---------------------------------------------------------
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=olist_forecasting

# ---------------------------------------------------------
# Embeddings  (local HuggingFace model — no API key)
# ---------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
